{
  "name": "guesthub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/prebuild-guard.mjs",
    "build": "next build --turbopack",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "docker exec -i supabase-db psql -U supabase_admin -d postgres < db/migrations/000_init_schema.sql",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "check:e2e-safety": "node scripts/check-e2e-safety.mjs",
    "check:commercial": "node scripts/check-commercial.mjs",
    "check:commercial-db": "node scripts/check-commercial-db.mjs",
    "check:room-pricing": "node scripts/check-room-pricing.mjs",
    "check:room-db": "node scripts/check-room-db.mjs",
    "check:settings-regression": "node scripts/check-settings-regression.mjs",
    "check:rate-plans": "node scripts/check-rate-plans.mjs",
    "check:pricing-engine": "node scripts/check-pricing-engine.mjs",
    "check:pricing-equality": "node scripts/check-pricing-equality.mjs",
    "check:rate-grid": "node --env-file=.env.local scripts/check-rate-grid.mjs",
    "check:effective-state": "node --env-file=.env.local scripts/check-effective-state.mjs",
    "check:inventory": "node --env-file=.env.local scripts/check-inventory.mjs",
    "check:sellability": "node --env-file=.env.local scripts/check-rate-sellability.mjs",
    "check:reservation-snapshot": "node scripts/check-reservation-snapshot.mjs",
    "check:calendar": "node scripts/check-calendar.mjs",
    "check:cards": "node scripts/check-cards.mjs",
    "check:payments": "node scripts/check-payments.mjs",
    "check:channel-card-ingest": "node --env-file=.env.local scripts/check-channel-card-ingest.mjs",
    "check:messaging": "node scripts/check-messaging.mjs",
    "check:channex-connection": "node scripts/check-channex-connection.mjs",
    "check:channex-properties": "node scripts/check-channex-properties.mjs",
    "check-e2e-safety": "node scripts/check-e2e-safety.mjs",
    "guard:deploy": "node scripts/production-deploy-guard.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.109.0",
    "@tanstack/react-table": "^8.21.3",
    "framer-motion": "11.18.2",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "nodemailer": "^9.0.3",
    "nuqs": "^2.9.0",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
