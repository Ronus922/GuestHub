{
  "name": "guesthub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/prebuild-guard.mjs",
    "build": "next build --turbopack",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "docker exec -i supabase-db psql -U supabase_admin -d postgres < db/migrations/000_init_schema.sql",
    "db:seed": "node --env-file=.env.local scripts/seed.mjs",
    "check:e2e-safety": "node scripts/check-e2e-safety.mjs",
    "check:commercial": "node scripts/check-commercial.mjs",
    "check:commercial-db": "node scripts/check-commercial-db.mjs",
    "check:room-pricing": "node scripts/check-room-pricing.mjs",
    "check:room-db": "node scripts/check-room-db.mjs",
    "check:settings-regression": "node scripts/check-settings-regression.mjs",
    "check:check-in-check-out": "node scripts/check-check-in-check-out.mjs",
    "check:check-in-check-out-db": "node scripts/check-check-in-check-out-db.mjs",
    "check:rate-plans": "node scripts/check-rate-plans.mjs",
    "check:pricing-engine": "node scripts/check-pricing-engine.mjs",
    "check:pricing-equality": "node scripts/check-pricing-equality.mjs",
    "check:rates-ui": "node scripts/check-rates-ui.mjs",
    "check:rate-grid": "node --env-file=.env.local scripts/check-rate-grid.mjs",
    "check:effective-state": "node --env-file=.env.local scripts/check-effective-state.mjs",
    "check:inventory": "node --env-file=.env.local scripts/check-inventory.mjs",
    "check:sellability": "node --env-file=.env.local scripts/check-rate-sellability.mjs",
    "check:reservation-snapshot": "node scripts/check-reservation-snapshot.mjs",
    "check:calendar": "node scripts/check-calendar.mjs",
    "check:channels-badge": "node scripts/check-channels-badge.mjs",
    "check:cards": "node scripts/check-cards.mjs",
    "check:payments": "node scripts/check-payments.mjs",
    "check:channel-card-ingest": "node scripts/check-channel-card-ingest.mjs",
    "check:messaging": "node scripts/check-messaging.mjs",
    "check:guest-communications": "node scripts/check-guest-communications.mjs && node scripts/check-guest-communications-automation.mjs && node scripts/check-guest-communications-worker.mjs",
    "check:guest-communications-db": "node scripts/check-guest-communications-db.mjs",
    "check:channex-connection": "node scripts/check-channex-connection.mjs",
    "check:channex-properties": "node scripts/check-channex-properties.mjs",
    "check:business-profile": "node scripts/check-business-profile.mjs",
    "check:maps-picker": "node scripts/check-maps-picker.mjs",
    "check-e2e-safety": "node scripts/check-e2e-safety.mjs",
    "guard:deploy": "node scripts/production-deploy-guard.mjs",
    "check:channex-room-types": "node scripts/check-channex-room-types.mjs",
    "check:channex-rate-plans": "node scripts/check-channex-rate-plans.mjs",
    "check:su-lifecycle": "node scripts/check-su-lifecycle.mjs",
    "check:room-identity": "node scripts/check-room-identity.mjs",
    "check:db-isolation": "node scripts/check-db-isolation.mjs",
    "check:channex-environment-routing": "node scripts/check-channex-environment-routing.mjs",
    "check:production-activation-guard": "node scripts/check-production-activation-guard.mjs",
    "check:channex-certification-evidence": "node scripts/check-channex-certification-evidence.mjs",
    "check:channex-full-sync-two-requests": "node scripts/check-channex-full-sync-two-requests.mjs",
    "check:channex-group-update-batching": "node scripts/check-channex-group-update-batching.mjs",
    "check:channex-rate-limit-cooldown": "node scripts/check-channex-rate-limit-cooldown.mjs",
    "check:channel-security": "node scripts/check-channel-security.mjs",
    "check:channel-chaos": "node scripts/check-channel-chaos.mjs",
    "check:channex-booking-crs-flow": "node scripts/check-channex-booking-crs-flow.mjs",
    "check:channex-certification": "node scripts/check-channex-certification.mjs",
    "check:housekeeping": "node scripts/check-housekeeping.mjs",
    "check:maintenance-closures": "node scripts/check-maintenance-closures.mjs",
    "check:reports": "node scripts/check-reports.mjs",
    "check:israel-market": "node scripts/check-israel-market.mjs",
    "db:replay": "node scripts/db/migrate.mjs",
    "postbuild": "tsc -p tsconfig.worker.json",
    "build:worker": "tsc -p tsconfig.worker.json",
    "worker": "node --env-file-if-exists=.env.local scripts/channel-worker.cjs",
    "check:agents-concurrency": "grep -q 'git add -p' AGENTS.md && grep -q 'git add -p' CLAUDE.md || { echo 'Concurrency section missing — a gen-catalog regen wiped it from AGENTS.md; restore from CLAUDE.md and add it to the DevOPS kit template on ai2u-vs1 (DECISIONS D90)'; exit 1; }",
    "check:channex-ari": "node scripts/check-channex-ari.mjs",
    "check:channel-worker": "node scripts/check-channel-worker.mjs",
    "check:inbound-bookings": "node scripts/check-inbound-bookings.mjs",
    "check:channex-credential": "node scripts/check-channex-credential.mjs",
    "check:channels-hydration": "node scripts/check-channels-hydration.mjs",
    "check:channels-fullsync-ui": "node scripts/check-channels-fullsync-ui.mjs",
    "check:rates-sync": "node scripts/check-rates-sync.mjs",
    "check:realtime": "node scripts/check-realtime-cancellation.mjs",
    "check:hydration-browser": "node --experimental-websocket --env-file=.env.local scripts/check-hydration-browser.mjs",
    "check:status-default": "node scripts/check-status-default.mjs",
    "check:calendar-ui": "node scripts/check-calendar-ui.mjs",
    "check:design": "node scripts/check-design-system.mjs",
    "check:datepicker": "node scripts/check-datepicker.mjs",
    "check:reservations-ui": "node --experimental-websocket scripts/check-reservations-ui.mjs",
    "check:reservation-concurrency": "node scripts/check-reservation-concurrency.mjs",
    "check:inventory-integrity": "node scripts/check-inventory-integrity.mjs",
    "check:payment-ledger-integrity": "node scripts/check-payment-ledger-integrity.mjs",
    "check:payment-refund-void": "node scripts/check-payment-refund-void.mjs",
    "check:timezone-and-money-invariants": "node scripts/check-timezone-and-money-invariants.mjs",
    "check:pms-domain-invariants": "node scripts/check-pms-domain-invariants.mjs",
    "check:background-job-recovery": "node scripts/check-background-job-recovery.mjs",
    "check:no-secrets": "node scripts/check-no-secrets.mjs",
    "check:supply-chain": "node scripts/check-supply-chain.mjs",
    "check:retention": "node scripts/check-retention.mjs",
    "check:performance": "node scripts/check-performance.mjs",
    "check:code-documentation": "node scripts/check-code-documentation.mjs"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hebcal/core": "^6.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.109.0",
    "@tanstack/react-table": "^8.21.3",
    "framer-motion": "11.18.2",
    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "nodemailer": "^9.0.3",
    "nuqs": "^2.9.0",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
